{
  "metadataType": "CustomLabels",
  "requiredForCreate": [
    "labels"
  ],
  "creationOptions": {
    "labelItemRequired": [
      "fullName",
      "value",
      "language",
      "shortDescription"
    ],
    "labelItemOptional": [
      "protected",
      "categories"
    ]
  },
  "basicRules": [
    "labels must be a non-empty array.",
    "Each labels item must contain all creationOptions.labelItemRequired fields.",
    "Each label fullName must be unique.",
    "language should be a valid locale code (for example en_US)."
  ],
  "minimalExample": {
    "labels": [
      {
        "fullName": "exampleLabel",
        "value": "This is an example label.",
        "language": "en_US",
        "shortDescription": "Example Label",
        "protected": false
      }
    ]
  }
}
