{
  "metadataType": "CustomApplication",
  "purpose": "Represents a custom or standard application containing tabs, descriptions, and logos.",
  "coreRequired": [
    "fullName",
    "label",
    "tabs"
  ],
  "commonlyUsedOptional": {
    "text": [
      "description",
      "defaultLandingTab",
      "logo",
      "setupExperience"
    ],
    "picklist": [
      "navType",
      "uiType"
    ],
    "boolean": [
      "isServiceCloudConsole"
    ],
    "relationship": [
      "brand",
      "preferences",
      "consoleConfig",
      "workspaceConfig"
    ]
  },
  "conditionalRules": [
    {
      "field": "isServiceCloudConsole",
      "requiredFields": [
        "workspaceConfig"
      ],
      "condition": "true"
    }
  ],
  "preValidationChecks": [
    "Ensure 'fullName' does not already exist.",
    "Check that 'tabs' are valid and exist in the org."
  ],
  "minimalExample": {
    "CustomApplication": {
      "fullName": "MyCustomApp",
      "label": "My Custom Application",
      "tabs": [
        "standard-Account",
        "standard-Contact"
      ]
    }
  }
}
