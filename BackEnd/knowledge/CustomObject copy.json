{
  "metadataType": "CustomObject",
  "purpose": "Represents a custom object that stores data unique to your organization or an external object that maps to external data.",
  "coreRequired": [
    "fullName",
    "label",
    "pluralLabel",
    "nameField",
    "sharingModel",
    "deploymentStatus"
  ],
  "commonlyUsedOptional": {
    "text": [
      "description",
      "enableActivities",
      "enableEnhancedLookup",
      "enableFeed",
      "enableHistory",
      "enableReports",
      "enableSearch",
      "enableSharing",
      "enableStreamingApi",
      "externalDataSource",
      "externalName",
      "gender"
    ],
    "boolean": [
      "allowInChatterGroups",
      "enableBulkApi",
      "enableDivisions",
      "enableLicensing",
      "household"
    ],
    "array": [
      "fields",
      "compactLayouts",
      "recordTypes",
      "validationRules",
      "webLinks"
    ]
  },
  "conditionalRules": [
    {
      "field": "nameField",
      "condition": "If creating an external object, the nameField can be specified by setting 'isNameField' to true in the CustomField component."
    }
  ],
  "preValidationChecks": [
    "Check if fullName is unique across the org.",
    "Verify required fields are included as per the definition."
  ],
  "minimalExample": {
    "CustomObject": {
      "fullName": "MyCustomObject__c",
      "label": "My Custom Object",
      "pluralLabel": "My Custom Objects",
      "nameField": {
        "label": "Custom Object Name",
        "type": "Text"
      },
      "sharingModel": "ReadWrite",
      "deploymentStatus": "Deployed"
    }
  }
}
