{
  "metadataType": "CustomTab",
  "requiredForCreate": [
    "fullName",
    "motif"
  ],
  "creationOptions": {
    "contentTargetOneOf": [
      "auraComponent",
      "customObject",
      "flexiPage",
      "lwcComponent",
      "page",
      "scontrol",
      "url"
    ],
    "optional": [
      "description",
      "label",
      "hasSidebar",
      "frameHeight",
      "splashPageLink",
      "urlEncodingKey"
    ]
  },
  "basicRules": [
    "fullName must be unique in the org.",
    "Exactly one field from creationOptions.contentTargetOneOf must be set.",
    "frameHeight is required when page or scontrol is used.",
    "If url is used, it must be a valid URL."
  ],
  "minimalExample": {
    "fullName": "MyCustomTab",
    "motif": "Custom53:Bell",
    "url": "https://www.example.com"
  }
}
