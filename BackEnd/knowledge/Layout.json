{
  "metadataType": "Layout",
  "purpose": "Represents the metadata associated with a page layout.",
  "coreRequired": [
    "fullName",
    "layoutSections"
  ],
  "commonlyUsedOptional": {
    "basic": [
      "customButtons",
      "excludeButtons",
      "miniLayoutFields",
      "quickActionList",
      "relatedLists"
    ],
    "feedLayout": [
      "feedLayout"
    ],
    "summaryLayout": [
      "summaryLayout"
    ],
    "layoutHeaders": [
      "headers"
    ]
  },
  "conditionalRules": [
    {
      "field": "showEmailCheckbox",
      "condition": "Only allowed on Case, CaseClose, and Task layouts."
    },
    {
      "field": "showRunAssignmentRulesCheckbox",
      "condition": "Only allowed on Case, Lead, and Account objects."
    },
    {
      "field": "showKnowledgeComponent",
      "condition": "Only allowed on Case layouts."
    }
  ],
  "preValidationChecks": [
    "Check if 'fullName' is unique within the organization.",
    "Ensure 'layoutSections' contains at least one section."
  ],
  "minimalExample": {
    "Layout": {
      "fullName": "MyLayout",
      "layoutSections": [
        {
          "editHeading": true,
          "label": "Section 1",
          "layoutColumns": [
            {
              "layoutItems": [
                {
                  "behavior": "Required",
                  "field": "Name"
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
