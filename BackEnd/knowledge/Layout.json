{
  "metadataType": "Layout",
  "requiredForCreate": [
    "fullName",
    "layoutSections"
  ],
  "creationOptions": {
    "optional": [
      "customButtons",
      "excludeButtons",
      "miniLayoutFields",
      "quickActionList",
      "relatedLists",
      "feedLayout",
      "summaryLayout",
      "headers"
    ],
    "layoutItemBehavior": [
      "Readonly",
      "Edit",
      "Required"
    ]
  },
  "basicRules": [
    "fullName must be unique in the org.",
    "layoutSections must be a non-empty array.",
    "Each layout section must contain at least one layout column and item.",
    "If behavior is used, it must be one of creationOptions.layoutItemBehavior."
  ],
  "minimalExample": {
    "fullName": "Account-MyLayout",
    "layoutSections": [
      {
        "editHeading": true,
        "label": "Main",
        "layoutColumns": [
          {
            "layoutItems": [
              {
                "behavior": "Required",
                "field": "Name"
              }
            ]
          }
        ]
      }
    ]
  }
}
