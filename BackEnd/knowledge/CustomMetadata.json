{
  "metadataType": "CustomMetadata",
  "requiredForCreate": [
    "fullName",
    "label"
  ],
  "creationOptions": {
    "optional": [
      "description",
      "protected",
      "values"
    ],
    "valuesItemRequired": [
      "field",
      "value"
    ]
  },
  "basicRules": [
    "fullName must follow CustomMetadataType__mdt.RecordName format.",
    "All requiredForCreate fields must be present.",
    "If values is provided, each item must contain field and value."
  ],
  "minimalExample": {
    "fullName": "MyCustomType__mdt.MyRecord",
    "label": "My Record",
    "values": [
      {
        "field": "MyCustomField__c",
        "value": "Some Value"
      }
    ]
  }
}
