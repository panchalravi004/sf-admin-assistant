{
  "metadataType": "CustomObject",
  "requiredForCreate": [
    "fullName",
    "label",
    "pluralLabel",
    "nameField",
    "sharingModel",
    "deploymentStatus"
  ],
  "creationOptions": {
    "nameField": {
      "required": [
        "label",
        "type"
      ],
      "allowedType": [
        "Text",
        "AutoNumber"
      ]
    },
    "sharingModel": [
      "Private",
      "Read",
      "ReadWrite",
      "ReadWriteTransfer",
      "ControlledByParent",
      "FullAccess"
    ],
    "deploymentStatus": [
      "Deployed",
      "InDevelopment"
    ]
  },
  "basicRules": [
    "fullName must end with __c and be unique in the org.",
    "All requiredForCreate fields must be present.",
    "nameField.type must be one of creationOptions.nameField.allowedType.",
    "sharingModel must be one of creationOptions.sharingModel.",
    "deploymentStatus must be one of creationOptions.deploymentStatus."
  ],
  "minimalExample": {
    "CustomObject": {
      "fullName": "MyCustomObject__c",
      "label": "My Custom Object",
      "pluralLabel": "My Custom Objects",
      "nameField": {
        "label": "Custom Object Name",
        "type": "Text"
      },
      "sharingModel": "ReadWrite",
      "deploymentStatus": "Deployed"
    }
  }
}
